{
  "name": "tada",
  "version": "0.1.0",
  "description": "ERP App",
  "homepage": "https://github.com/NguyenThanhDuyOfficial/TaDa",
  "licenses": [
    {
      "license": "GPLv3"
    }
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"dotenv -e .env -- npm run dev --workspace=apps/api\" \"dotenv -e .env -- npm run dev --workspace=apps/web\"",
    "dev:api": "dotenv -e .env -- npm run dev --workspace=apps/api",
    "dev:web": "dotenv -e .env -- npm run dev --workspace=apps/web",
    "prisma:generate": "dotenv -e .env -- prisma generate --schema=apps/api/prisma/schema.prisma --config=apps/api/prisma.config.ts",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev --schema=apps/api/prisma/schema.prisma --config=apps/api/prisma.config.ts",
    "test": "jest"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.3.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
